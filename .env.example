# mcpx configuration. Copy to .env (never commit a real .env).
# All variables are optional; defaults are shown.

# --- Transport ---
# stdio | http
MCPX_TRANSPORT=stdio
MCPX_HTTP_HOST=127.0.0.1
MCPX_HTTP_PORT=8080

# --- Limits (bytes / seconds) ---
MCPX_MAX_OUTPUT=65536
MCPX_MAX_OUTPUT_HARD=1048576
MCPX_DEFAULT_TIMEOUT=60
MCPX_MAX_TIMEOUT=900
MCPX_MAX_SESSIONS=64
MCPX_SESSION_IDLE_TIMEOUT=1800
MCPX_SESSION_BUFFER_BYTES=262144

# --- Policy ---
# open | guarded | readonly
#   open     : full access (default; matches the documented single-owner posture)
#   guarded  : Tier 2+ commands are refused unless MCPX_POLICY_ALLOW matches
#   readonly : only Tier 0 (read-only) commands permitted
MCPX_POLICY_MODE=open
MCPX_POLICY_DENY=
MCPX_POLICY_ALLOW=

# --- Audit ---
MCPX_AUDIT_PATH=/var/log/mcpx/audit.jsonl
MCPX_AUDIT_STDERR=false

# --- SSH ---
MCPX_SSH_CONFIG=~/.ssh/config
MCPX_INVENTORY=
# strict | accept-new | ignore
MCPX_SSH_KNOWN_HOSTS=accept-new
MCPX_SSH_CONNECT_TIMEOUT=10
MCPX_SSH_KEEPALIVE=30

# --- OAuth 2.1 (HTTP transport only; requires the [http] extra) ---
MCPX_AUTH_ENABLED=false
MCPX_AUTH_ISSUER=https://localhost:8080
MCPX_AUTH_STATE_DIR=/var/lib/mcpx/oauth
MCPX_AUTH_SINGLE_CLIENT=true
MCPX_AUTH_ACCESS_TTL=3600
MCPX_AUTH_REFRESH_TTL=2592000
MCPX_AUTH_CODE_TTL=300
